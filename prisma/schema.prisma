generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  password      String
  name          String
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  emailVerified           Boolean   @default(false)
  verificationCode        String?
  verificationCodeExpires DateTime?
  verificationCodeIssuedAt DateTime? // Hora exacta de emisión, para cooldown de reenvío. Sin este campo lo calculábamos como expires-10min y se rompía cuando cambiábamos la duración del código.
  verificationAttempts    Int       @default(0)
  pendingEmail            String?   // Email nuevo en espera de verificación tras un cambio
  resetToken              String?   // Hash SHA-256 del token de reset (32 bytes random ya entropía alta — bcrypt no aporta y bloquea CPU)
  resetTokenExpires       DateTime?
  tokenVersion            Int       @default(0)  // Embebido en cada JWT. Bumpear este número invalida TODAS las sesiones del usuario (cambio de contraseña / email / logout-everywhere).
  lang                    String    @default("es")  // Idioma preferido para los emails ('es' | 'en'). Lo recibimos del frontend en signup y en el toggle de idioma del app.

  bots          Bot[]
  brokers       BrokerConnection[]
  subscriptions Subscription[]
  referralCode  String?    @unique
  referredBy    String?

  @@map("users")
}

model Bot {
  id            String     @id @default(cuid())
  userId        String
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  name          String
  description   String?
  strategy      String
  parameters    Json
  status        String     @default("draft")

  // ID de la orden de Lemon Squeezy que pagó este bot. Único en BD para que
  // dos requests concurrentes a /verify no puedan crear el mismo bot dos veces.
  // Las filas previas a este campo tienen NULL — solo aplica el unique a no-NULL.
  lemonOrderId  String?    @unique

  brokerConnectionId String?
  brokerConnection   BrokerConnection? @relation(fields: [brokerConnectionId], references: [id])

  botTemplateId String?
  botTemplate   BotTemplate? @relation(fields: [botTemplateId], references: [id])

  totalProfit   Float      @default(0)
  winRate       Float      @default(0)
  trades        Trade[]

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@map("bots")
}

model BotTemplate {
  id            String     @id @default(cuid())
  name          String
  description   String
  strategy      String
  price         Float
  image         String?
  parameters    Json

  bots          Bot[]

  createdAt     DateTime   @default(now())
  @@map("bot_templates")
}

model BrokerConnection {
  id            String     @id @default(cuid())
  userId        String
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  brokerName    String
  apiKey        String
  apiSecret     String
  accountId     String?
  isActive      Boolean    @default(true)

  bots          Bot[]

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@unique([userId, brokerName])
  @@map("broker_connections")
}

model Trade {
  id            String     @id @default(cuid())
  botId         String
  bot           Bot        @relation(fields: [botId], references: [id], onDelete: Cascade)

  symbol        String
  type          String
  quantity      Float
  price         Float
  profit        Float?

  openedAt      DateTime   @default(now())
  closedAt      DateTime?

  @@map("trades")
}

model Subscription {
  id            String     @id @default(cuid())
  userId        String
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  botTemplateId String
  stripeSessionId String?

  status        String     @default("pending")
  startDate     DateTime   @default(now())
  endDate       DateTime?

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@map("subscriptions")
}
