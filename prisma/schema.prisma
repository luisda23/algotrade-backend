generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  password      String
  name          String
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  emailVerified           Boolean   @default(false)
  verificationCode        String?
  verificationCodeExpires DateTime?
  verificationAttempts    Int       @default(0)
  pendingEmail            String?   // Email nuevo en espera de verificación tras un cambio
  resetToken              String?   // Hash bcrypt del token de recuperación de contraseña
  resetTokenExpires       DateTime?

  bots          Bot[]
  brokers       BrokerConnection[]
  subscriptions Subscription[]
  referralCode  String?    @unique
  referredBy    String?

  @@map("users")
}

model Bot {
  id            String     @id @default(cuid())
  userId        String
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  name          String
  description   String?
  strategy      String
  parameters    Json
  status        String     @default("draft")

  brokerConnectionId String?
  brokerConnection   BrokerConnection? @relation(fields: [brokerConnectionId], references: [id])

  botTemplateId String?
  botTemplate   BotTemplate? @relation(fields: [botTemplateId], references: [id])

  totalProfit   Float      @default(0)
  winRate       Float      @default(0)
  trades        Trade[]

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@map("bots")
}

model BotTemplate {
  id            String     @id @default(cuid())
  name          String
  description   String
  strategy      String
  price         Float
  image         String?
  parameters    Json

  bots          Bot[]

  createdAt     DateTime   @default(now())
  @@map("bot_templates")
}

model BrokerConnection {
  id            String     @id @default(cuid())
  userId        String
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  brokerName    String
  apiKey        String
  apiSecret     String
  accountId     String?
  isActive      Boolean    @default(true)

  bots          Bot[]

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@unique([userId, brokerName])
  @@map("broker_connections")
}

model Trade {
  id            String     @id @default(cuid())
  botId         String
  bot           Bot        @relation(fields: [botId], references: [id], onDelete: Cascade)

  symbol        String
  type          String
  quantity      Float
  price         Float
  profit        Float?

  openedAt      DateTime   @default(now())
  closedAt      DateTime?

  @@map("trades")
}

model Subscription {
  id            String     @id @default(cuid())
  userId        String
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  botTemplateId String
  stripeSessionId String?

  status        String     @default("pending")
  startDate     DateTime   @default(now())
  endDate       DateTime?

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@map("subscriptions")
}
